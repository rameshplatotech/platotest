<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Google Search Suite" parallel="methods" thread-count="2" verbose="2">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <parameter name="base_url" value="https://www.google.com/"/>

    <test name="Google Search Tests" parallel="methods" thread-count="2">
        <classes>
            <class name="com.playwright.tests.GoogleSearchTest"/>
        </classes>
    </test>
</suite>